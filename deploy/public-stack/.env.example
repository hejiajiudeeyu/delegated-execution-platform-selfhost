# Public HTTPS origin for the deployed edge.
# Keep localhost only for local compose tests; public exposure is blocked until this is a real HTTPS origin.
PUBLIC_SITE_ADDRESS=http://localhost
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

IMAGE_REGISTRY=ghcr.io/hejiajiudeeyu
# Use a concrete release tag such as v0.1.x for first public pulls; do not expose latest.
# The Images workflow publishes release-tagged images after the matching tag is pushed.
IMAGE_TAG=latest

PLATFORM_PORT=8080
RELAY_PORT=8090
GATEWAY_PORT=8085
POSTGRES_PORT=5432

POSTGRES_DB=croc
POSTGRES_USER=croc
# Generate a strong value before public exposure; do not reuse the example.
POSTGRES_PASSWORD=croc
DATABASE_URL=postgresql://croc:croc@postgres:5432/croc

# Generate with selfhost:init or an equivalent secret manager before public exposure.
TOKEN_SECRET=change-me-public-token-secret
TOKEN_TTL_SECONDS=300
# Generate a strong operator key and store it through the console gateway; do not publish it in logs.
PLATFORM_ADMIN_API_KEY=sk_admin_change_me
# Required for first setup of the public console gateway. Store out-of-band and rotate after bootstrap.
PLATFORM_CONSOLE_BOOTSTRAP_SECRET=change-me-public-bootstrap-secret
# Wave 3 paid-call regression assumes production public-stack enforces prepaid billing.
BILLING_ENFORCEMENT=enforced

ENABLE_BOOTSTRAP_RESPONDERS=false
BOOTSTRAP_RESPONDER_ID=
BOOTSTRAP_HOTLINE_ID=
BOOTSTRAP_TASK_DELIVERY_ADDRESS=
BOOTSTRAP_RESPONDER_API_KEY=
BOOTSTRAP_RESPONDER_PUBLIC_KEY_PEM=
BOOTSTRAP_RESPONDER_PRIVATE_KEY_PEM=
