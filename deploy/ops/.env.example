IMAGE_REGISTRY=ghcr.io/hejiajiudeeyu
IMAGE_TAG=latest

CALLER_PORT=8081
RESPONDER_PORT=8082
RELAY_PORT=8090

PLATFORM_API_BASE_URL=http://host.docker.internal:8080
CALLER_PLATFORM_API_KEY=

CALLER_TRANSPORT_RECEIVER=caller-controller
RESPONDER_TRANSPORT_RECEIVER=responder-local

ACK_DEADLINE_S=120
TIMEOUT_CONFIRMATION_MODE=ask_by_default
HARD_TIMEOUT_AUTO_FINALIZE=true
CALLER_CONTROLLER_POLL_INTERVAL_ACTIVE_S=5
CALLER_CONTROLLER_POLL_INTERVAL_BACKOFF_S=15
CALLER_CONTROLLER_INBOX_POLL_INTERVAL_MS=250
CALLER_CONTROLLER_EVENTS_SYNC_INTERVAL_MS=250

RESPONDER_ID=responder_local
HOTLINE_IDS=local.hotline.v1
RESPONDER_SIGNING_PUBLIC_KEY_PEM=
RESPONDER_SIGNING_PRIVATE_KEY_PEM=
RESPONDER_MAX_HARD_TIMEOUT_S=300
RESPONDER_ALLOWED_TASK_TYPES=
RESPONDER_HEARTBEAT_INTERVAL_MS=30000
RESPONDER_INBOX_POLL_INTERVAL_MS=250
